{
  "name": "conductor/drupal-platform-support",
  "version": "3.0.0",
  "description": "Conductor Drupal Platform Support",
  "type": "library",
  "homepage": "https://github.com/conductorphp/conductor-drupal-platform-support",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Kirk Madera",
      "email": "kirk.madera@rmgmedia.com",
      "role": "Architect"
    }
  ],
  "config": {
    "sort-packages": true
  },
  "require": {
    "php": "~8.2.0|~8.3.0|~8.4.0|~8.5.0",
    "conductor/application-orchestration": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^5.7.23 || ^6.4.3",
    "laminas/laminas-coding-standard": "~1.0.0"
  },
  "autoload": {
    "psr-4": {
      "ConductorDrupalPlatformSupport\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ConductorDrupalPlatformSupportTest\\": "test/"
    }
  },
  "extra": {
    "laminas": {
      "config-provider": "ConductorDrupalPlatformSupport\\ConfigProvider"
    }
  },
  "scripts": {
    "check": [
      "@cs-check",
      "@test"
    ],
    "cs-check": "phpcs",
    "cs-fix": "phpcbf",
    "test": "phpunit --colors=always",
    "test-coverage": "phpunit --colors=always --coverage-clover clover.xml"
  }
}